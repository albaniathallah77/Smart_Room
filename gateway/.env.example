GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.1-8b-instant
TAVILY_API_KEY=your_tavily_key

# Remote web control PIN and ESP32 polling token.
DASHBOARD_PIN=2008
DEVICE_TOKEN=change-this-device-token

# Supabase memory/history.
# On Vercel, add these in Project Settings -> Environment Variables.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Leave this empty on Vercel because Vercel cannot reach your local ESP32 IP.
# The ESP32 dashboard browser sends returned commands to the ESP32 locally.
# ESP32_BASE_URL=http://192.168.1.25
PORT=8787
